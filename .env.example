# OpenAI (required when LLM_PROVIDER=openai or EMBED_PROVIDER=openai)
OPENAI_API_KEY=

# OpenCode Zen (required only when LLM_PROVIDER=zen)
ZEN_API_KEY=

# LLM Configuration (optional, defaults shown)
LLM_PROVIDER=openai
# LLM_PROVIDER=zen
LLM_MODEL=gpt-4o-mini
# LLM_API_BASE=https://opencode.ai/zen/v1

# Embedding Configuration (optional, defaults shown)
EMBED_PROVIDER=openai
# EMBED_PROVIDER=huggingface
EMBED_MODEL=text-embedding-3-small
# EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIMS=1536
# EMBED_DIMS=384

# Qdrant Configuration (optional, defaults shown)
QDRANT_HOST=localhost
QDRANT_PORT=6333
