# Required (for embeddings, and for LLM when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# OpenCode Zen (optional — required only when LLM_PROVIDER=zen)
ZEN_API_KEY=

# LLM Configuration (optional, defaults shown)
LLM_PROVIDER=openai
# LLM_PROVIDER=zen
LLM_MODEL=gpt-4o-mini
# LLM_API_BASE=https://opencode.ai/zen/v1

# Embedding Configuration (optional, defaults shown)
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small

# Qdrant Configuration (optional, defaults shown)
QDRANT_HOST=localhost
QDRANT_PORT=6333
